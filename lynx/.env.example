# Supabase — copy to .env.local and fill in from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# AI (optional — Phase 9). Add your key to .env.local to enable AI features:
# ANTHROPIC_API_KEY=sk-ant-...
# Or use OpenAI instead/as well:
# GEMINI_API_KEY=AIza...   (Google AI Studio)
# OPENAI_API_KEY=sk-...
